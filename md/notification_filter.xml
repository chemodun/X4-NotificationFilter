<mdscript name="Notification_Filter" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <cues>

    <cue name="Main" version="1">
      <actions>
        <debug_text text="'NotificationFilter: Main'" chance="100" filter="scripts" />
        <include_actions ref="md.Notification_Filter.DefaultFilters" />
        <remove_value name="$filters" />
      </actions>
    </cue>


    <library name="DefaultFilters" purpose="include_actions" version="4">
      <actions>
        <do_if value="@player.entity.$notificationFilters == null">
          <set_value name="player.entity.$notificationFilters" exact="table[
            $reputation = 1,
            $reputationLogbook = 1,
            $money = 100000,
            $craftingProgress = false,
            $insufficientFunds = false,
            $insufficientFundsLogbook = false,
            $shipConstructedClassS = false,
            $shipConstructedClassM = false,
            $shipConstructedClassL = false,
            $shipConstructedClassXL = false,
            $shipConstructedMoney = 0,
            $ammoCollected = false,
            $ammoReceived = false,
            $inventoryCollected = false,
            $droppedContainerCollected = false,
            $materialsCollected = false,
            $storageFull = false,
            $debugChance = 0
          ]" />
        </do_if>
        <set_value name="$filters" exact="@player.entity.$notificationFilters" />
        <set_value name="$notificationFiltersDebugChance" exact="$filters.$debugChance" />
        <do_if value="$filters.$shipConstructedMoney? == false">
          <set_value name="$filters.$shipConstructedMoney" exact="0" />
        </do_if>
        <do_if value="$filters.$shipConstructedClassS? == false">
          <set_value name="$filters.$shipConstructedClassS" exact="false" />
        </do_if>
        <do_if value="$filters.$shipConstructedClassM? == false">
          <set_value name="$filters.$shipConstructedClassM" exact="false" />
        </do_if>
        <do_if value="$filters.$shipConstructedClassL? == false">
          <set_value name="$filters.$shipConstructedClassL" exact="false" />
        </do_if>
        <do_if value="$filters.$shipConstructedClassXL? == false">
          <set_value name="$filters.$shipConstructedClassXL" exact="false" />
        </do_if>
        <do_if value="$filters.$ammoCollected? == false">
          <set_value name="$filters.$ammoCollected" exact="false" />
        </do_if>
        <do_if value="$filters.$ammoReceived? == false">
          <set_value name="$filters.$ammoReceived" exact="false" />
        </do_if>
        <do_if value="$filters.$inventoryCollected? == false">
          <set_value name="$filters.$inventoryCollected" exact="false" />
        </do_if>
        <do_if value="$filters.$droppedContainerCollected? == false">
          <set_value name="$filters.$droppedContainerCollected" exact="false" />
        </do_if>
        <do_if value="$filters.$materialsCollected? == false">
          <set_value name="$filters.$materialsCollected" exact="false" />
        </do_if>
        <do_if value="$filters.$storageFull? == false">
          <set_value name="$filters.$storageFull" exact="false" />
        </do_if>
      </actions>
    </library>

    <library name="Filter_BaseRelationChanged_Notification_up" purpose="include_actions">
      <actions>
        <include_actions ref="md.Notification_Filter.DefaultFilters" />
        <set_value name="$relationFilter" exact="$filters.$reputation" />
        <debug_text text="'NotificationFilter: Relation changed: Old: %s, New: %s, Filter: %s. Abc: %s. Compare: %s.' . [$oldnum, $newnum, $relationFilter, abs($oldnum - $newnum), abs($oldnum - $newnum) ge $relationFilter]" chance="@$notificationFiltersDebugChance" filter="scripts" />
        <do_if value="abs($oldnum - $newnum) ge $relationFilter ">
          <debug_text text="'NotificationFilter: Showing notification. Old: %s, New: %s, Filter: %s. Abc: %s. Compare: %s. Text: %s' . [$oldnum, $newnum, $relationFilter, abs($oldnum - $newnum), abs($oldnum - $newnum) gt $relationFilter, $tickertext]" chance="@$notificationFiltersDebugChance" filter="scripts" />
          <show_notification text="$tickertext" sound="ui_mon_eve_notoriety_up" />
        </do_if>
        <remove_value name="$filters" />
        <remove_value name="$relationFilter" />
      </actions>
    </library>

    <library name="Filter_BaseRelationChanged_Notification_down" purpose="include_actions">
      <actions>
        <include_actions ref="md.Notification_Filter.DefaultFilters" />
        <set_value name="$relationFilter" exact="$filters.$reputation" />
        <debug_text text="'NotificationFilter: Relation changed: Old: %s, New: %s, Filter: %s. Abc: %s. Compare: %s.' . [$oldnum, $newnum, $relationFilter, abs($oldnum - $newnum), abs($oldnum - $newnum) ge $relationFilter]" chance="@$notificationFiltersDebugChance" filter="scripts" />
        <do_if value="abs($oldnum - $newnum) ge $relationFilter">
          <debug_text text="'NotificationFilter: Showing notification. Old: %s, New: %s, Filter: %s. Abc: %s. Compare: %s. Text: %s' . [$oldnum, $newnum, $relationFilter, abs($oldnum - $newnum), abs($oldnum - $newnum) ge $relationFilter, $tickertext]" chance="@$notificationFiltersDebugChance" filter="scripts" />
          <show_notification text="$tickertext" sound="ui_mon_eve_notoriety_down" />
        </do_if>
        <remove_value name="$filters" />
        <remove_value name="$relationFilter" />
      </actions>
    </library>

    <library name="Filter_BaseRelationChanged_Logbook" purpose="include_actions">
      <actions>
        <include_actions ref="md.Notification_Filter.DefaultFilters" />
        <set_value name="$relationFilter" exact="$filters.$reputationLogbook" />
        <debug_text text="'NotificationFilter: Logbook relation changed: Old: %s, New: %s, Filter: %s. Abc: %s. Compare: %s.' . [$oldnum, $newnum, $relationFilter, abs($oldnum - $newnum), abs($oldnum - $newnum) ge $relationFilter]" chance="@$notificationFiltersDebugChance" filter="scripts" />
        <do_if value="abs($oldnum - $newnum) ge $relationFilter">
          <debug_text text="'NotificationFilter: Writing to logbook. Old: %s, New: %s, Filter: %s. Abc: %s. Compare: %s. Title: %s. Text: %s' . [$oldnum, $newnum, $relationFilter, abs($oldnum - $newnum), abs($oldnum - $newnum) ge $relationFilter, $title, $logtext]" chance="@$notificationFiltersDebugChance" filter="scripts" />
          <write_to_logbook category="general" title="$title" faction="event.param" text="$logtext" />
        </do_if>
        <remove_value name="$filters" />
        <remove_value name="$relationFilter" />
      </actions>
    </library>

    <library name="Filter_layerMoneyTransfer_Notification_up" purpose="include_actions">
      <actions>
        <include_actions ref="md.Notification_Filter.DefaultFilters" />
        <set_value name="$moneyFilter" exact="$filters.$money * 1Cr" />
        <set_value name="$notFiltered" exact="(event.param2 - event.param) gt $moneyFilter" />
        <debug_text text="'NotificationFilter: Up. Money transfer: %s. Balance: %s. Filter: %s. Filtered: %s' . [event.param2 - event.param, event.param2, $moneyFilter, not $notFiltered]" chance="@$notificationFiltersDebugChance" filter="scripts" />
        <do_if value="$notFiltered">
          <show_notification text="$message" sound="ui_mon_eve_money_up" />
        </do_if>
        <remove_value name="$filters" />
        <remove_value name="$moneyFilter" />
        <remove_value name="$notFiltered" />
      </actions>
    </library>

    <library name="Filter_layerMoneyTransfer_Notification_down" purpose="include_actions">
      <actions>
        <include_actions ref="md.Notification_Filter.DefaultFilters" />
        <set_value name="$moneyFilter" exact="$filters.$money * 1Cr" />
        <set_value name="$notFiltered" exact="(event.param - event.param2) gt $moneyFilter" />
        <debug_text text="'NotificationFilter: Down. Money transfer: %s. Balance: %s. Filter: %s. Filtered: %s' . [event.param2 - event.param, event.param2, $moneyFilter, not $notFiltered]" chance="@$notificationFiltersDebugChance" filter="scripts" />
        <do_if value="not $notFiltered">
          <show_notification text="$message" sound="ui_mon_eve_money_down" />
        </do_if>
        <remove_value name="$filters" />
        <remove_value name="$moneyFilter" />
        <remove_value name="$notFiltered" />
      </actions>
    </library>

    <library name="Filter_NotificationCraftingProgress" purpose="include_actions">
      <actions>
        <include_actions ref="md.Notification_Filter.DefaultFilters" />
        <set_value name="$craftingProgress" exact="$filters.$craftingProgress * 1Cr" />
        <debug_text text="'NotificationFilter: Crafting progress: Products count: %s.' . [@$products.count]" chance="@$notificationFiltersDebugChance" filter="scripts" />
        <do_if value="$craftingProgress != true">
          <include_actions ref="md.Notifications.NotificationCraftingProgress" />
        </do_if>
        <remove_value name="$filters" />
        <remove_value name="$craftingProgress" />
      </actions>
    </library>

    <library name="Filter_DropCollected_AmmoCollected" purpose="include_actions">
      <actions>
        <include_actions ref="md.Notification_Filter.DefaultFilters" />
        <debug_text text="'NotificationFilter: Ammo collected filter: %s' . [$filters.$ammoCollected]" chance="@$notificationFiltersDebugChance" filter="scripts" />
        <do_if value="$filters.$ammoCollected != true">
          <show_notification text="[{1015,42}, '', event.param.name, event.param2]" comment="Ammo collected" />
        </do_if>
        <remove_value name="$filters" />
      </actions>
    </library>

    <library name="Filter_DropCollected_AmmoReceived" purpose="include_actions">
      <actions>
        <include_actions ref="md.Notification_Filter.DefaultFilters" />
        <debug_text text="'NotificationFilter: Ammo received filter: %s' . [$filters.$ammoReceived]" chance="@$notificationFiltersDebugChance" filter="scripts" />
        <do_if value="$filters.$ammoReceived != true">
          <show_notification text="[{1015,50}, '', event.param.name, event.param2]" comment="Ammo received" />
        </do_if>
        <remove_value name="$filters" />
      </actions>
    </library>

    <library name="Filter_DropCollected_Ware_Base" purpose="include_actions">
      <!-- Sets $filterWareNotification=true if the current ware notification type should be suppressed -->
      <actions>
        <include_actions ref="md.Notification_Filter.DefaultFilters" />
        <set_value name="$filterWareNotification" exact="false" />
        <do_if value="event.param.isinventory">
          <set_value name="$filterWareNotification" exact="$filters.$inventoryCollected" />
        </do_if>
        <do_elseif value="event.param3.isclass.collectablewares and event.param3.isdroppedcontainer">
          <set_value name="$filterWareNotification" exact="$filters.$droppedContainerCollected" />
        </do_elseif>
        <do_else>
          <set_value name="$filterWareNotification" exact="$filters.$materialsCollected" />
        </do_else>
        <debug_text text="'NotificationFilter: Ware notification type filter: isinventory=%s, isdroppedcontainer=%s, filtered=%s' . [event.param.isinventory, @event.param3.isdroppedcontainer, $filterWareNotification]" chance="@$notificationFiltersDebugChance" filter="scripts" />
        <remove_value name="$filters" />
      </actions>
    </library>

    <library name="Filter_DropCollected_Ware_Important" purpose="include_actions">
      <!-- Replaces show_notification inside do_if[$important?] for filtered ware collection -->
      <actions>
        <include_actions ref="md.Notification_Filter.Filter_DropCollected_Ware_Base" />
        <do_if value="not $filterWareNotification">
          <show_notification text="$tickertext" priority="$priority" sound="notification_rareitemcollected" />
        </do_if>
        <remove_value name="$filterWareNotification" />
      </actions>
    </library>

    <library name="Filter_DropCollected_Ware_Normal" purpose="include_actions">
      <!-- Replaces show_notification inside do_else (non-important) for filtered ware collection -->
      <actions>
        <include_actions ref="md.Notification_Filter.Filter_DropCollected_Ware_Base" />
        <do_if value="not $filterWareNotification">
          <show_notification text="$tickertext" priority="$priority" />
        </do_if>
        <remove_value name="$filterWareNotification" />
      </actions>
    </library>

    <library name="Filter_CollectDropFailed_StorageFull" purpose="include_actions">
      <!-- Replaces show_notification in CollectDropFailed_NoCargoStorage -->
      <actions>
        <include_actions ref="md.Notification_Filter.DefaultFilters" />
        <debug_text text="'NotificationFilter: Storage full filter: %s' . [$filters.$storageFull]" chance="@$notificationFiltersDebugChance" filter="scripts" />
        <do_if value="$filters.$storageFull != true">
          <show_notification text="[$caption, '', event.param.name, event.param2, $storagetext, '']" priority="2" timeout="7s" />
        </do_if>
        <remove_value name="$filters" />
      </actions>
    </library>

  </cues>

</mdscript>